# ================================================================
# gidas-identity — Environment variables (overrides for SOPS secrets)
# ================================================================
# These are OPTIONAL overrides. By default, all configuration is
# loaded from the SOPS-encrypted secrets file.
#
# Copy to .env and fill in only if you need to override specific
# values without re-encrypting secrets.yaml.
# ================================================================

# Path to SOPS-encrypted secrets YAML
# GIDAS_SECRETS_PATH=/secrets/identity.yaml

# SOPS age key file
# SOPS_AGE_KEY_FILE=/home/appuser/.config/sops/age/keys.txt

# Timezone
# TZ=America/Argentina/Buenos_Aires
