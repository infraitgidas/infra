# ============================================================
# .env.example — LibreNMS GIDAS
# Copiar a .env y completar antes de docker compose up
# ============================================================

# Web
APP_URL=https://nms.gidas.local

# DB (generar passwords con: openssl rand -hex 16)
DB_ROOT_PASSWORD=__CAMBIAR_DB_ROOT_PW__
DB_PASSWORD=__CAMBIAR_DB_PASSWORD__

# LDAP / AD — configurado en /data/config/config.php
# auth_mechanism=active_directory
# auth_ad_domain=GDC01.local
# auth_ad_url=ldap://192.168.1.117
# auth_ad_base_dn=DC=GDC01,DC=local
# auth_ad_binduser=infrait
# auth_ad_bindpassword=__LDAP_BIND_PASSWORD__

# SMTP — Office 365
MAIL_DRIVER=smtp
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=infrait@frlp.utn.edu.ar
MAIL_PASSWORD=__SMTP_PASSWORD__
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=infrait@frlp.utn.edu.ar
MAIL_FROM_NAME=LibreNMS GIDAS
