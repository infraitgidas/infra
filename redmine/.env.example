# Redmine Docker Compose — Secrets Template
# Copy to .env and fill values, or use sops-decrypted secrets/redmine.yaml
#
# Generate with:
#   POSTGRES_PASSWORD=$(openssl rand -base64 24)
#   REDMINE_SECRET_KEY=$(openssl rand -hex 32)

POSTGRES_DB=redmine
POSTGRES_USER=redmine
POSTGRES_PASSWORD=changeme
REDMINE_SECRET_KEY=changeme
