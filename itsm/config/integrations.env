# ================================================================
# integrations.env — GLPI Integration Configuration
# ================================================================
# Source this file before running webhook scripts:
#   source config/integrations.env
# ================================================================
# WARNING: API tokens are secrets. Set restrictive permissions:
#   chmod 600 config/integrations.env
# ================================================================

# --- Redmine ---
# Base URL of the Redmine instance
REDMINE_URL="${REDMINE_URL:-https://redmine.gidas.local}"

# Redmine API key (user profile > API access key)
REDMINE_API_KEY="${REDMINE_API_KEY:-}"

# Redmine project ID where GLPI change issues will be created
REDMINE_PROJECT_ID="${REDMINE_PROJECT_ID:-glpi-integration}"

# GLPI → Redmine mapping: GLPI change status values that trigger creation
# comma-separated: 1=New, 2=Accepted, 3=In Progress, 4=Resolved, 5=Closed
REDMINE_TRIGGER_STATUS="${REDMINE_TRIGGER_STATUS:-1,2}"

# --- GitLab ---
# Base URL of the GitLab instance
GITLAB_URL="${GITLAB_URL:-https://gitlab.gidas.local}"

# GitLab personal access token (with api scope)
GITLAB_TOKEN="${GITLAB_TOKEN:-}"

# GitLab project ID (numeric or URL-encoded path)
GITLAB_PROJECT_ID="${GITLAB_PROJECT_ID:-gidas/glpi-tickets}"

# GLPI → GitLab mapping: GLPI incident status values that trigger a comment
# 4=Resolved, 5=Closed
GITLAB_TRIGGER_STATUS="${GITLAB_TRIGGER_STATUS:-4,5}"

# --- Polling ---
# How far back to check for changes (in minutes)
POLL_INTERVAL_MINUTES="${POLL_INTERVAL_MINUTES:-5}"

# State file directory (tracks last poll timestamp)
STATE_DIR="${STATE_DIR:-/var/lib/glpi-integrations}"

# --- GLPI API ---
# GLPI API base URL (internal Docker network)
GLPI_API_URL="${GLPI_API_URL:-http://glpi:80/apirest.php}"

# GLPI App-Token (generated during install)
GLPI_APP_TOKEN="${GLPI_APP_TOKEN:-}"

# GLPI API credentials (a tech user with API access)
GLPI_API_USER="${GLPI_API_USER:-glpi}"
GLPI_API_PASS="${GLPI_API_PASS:-}"
