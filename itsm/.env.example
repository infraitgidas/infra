# ================================================================
# GLPI ITSM — Environment Configuration
# ================================================================
# Copy this file to .env and adjust values:
#   cp .env.example .env
# ================================================================

# --- MariaDB ---
MYSQL_ROOT_PASSWORD=glpi_root_secret
MYSQL_DATABASE=glpi
MYSQL_USER=glpi
MYSQL_PASSWORD=glpi_password

# --- GLPI ---
GLPI_TIMEZONE=America/Argentina/Buenos_Aires
GLPI_ADMIN_EMAIL=admin@gidas.local
GLPI_LANG=es_AR

# --- nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_SERVER_NAME=glpi.gidas.local

# --- LDAP ---
# LDAP_HOST=ipa.gidas.local
# LDAP_PORT=636
# LDAP_BIND_DN=cn=glpi-svc,cn=sysaccounts,cn=etc,dc=gidas,dc=local
# LDAP_BASE_DN=cn=users,cn=accounts,dc=gidas,dc=local
# LDAP_TLS=true

# --- Integrations ---
# REDMINE_URL=https://redmine.gidas.local
# GITLAB_URL=https://gitlab.gidas.local
