# ============================================================
# .env.example — Variables de entorno para Vaultwarden
# Copiar a .env y completar los valores reales
# ============================================================

# Dominio público
DOMAIN=https://vault.gidas.local

# Seguridad
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=true

# Admin panel (generar con: openssl rand -hex 32)
ADMIN_TOKEN=__CAMBIAR_ESTE_TOKEN__

# LDAP — AD GDC01
LDAP_URL=ldap://192.168.1.117
LDAP_START_TLS=false
LDAP_BIND_DN="CN=infrait,OU=ServiceAccounts,DC=GDC01,DC=local"
LDAP_BIND_PASSWORD=__LDAP_BIND_PASSWORD__
LDAP_SEARCH_BASE="DC=GDC01,DC=local"
LDAP_SEARCH_FILTER="(|(mail={{username}})(sAMAccountName={{username}}))"
LDAP_MAIL_ATTRIBUTE=mail
LDAP_USER_ATTRIBUTE=sAMAccountName

# SMTP — Correo para invitaciones y notificaciones
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SSL=true
SMTP_EXPLICIT_TLS=true
SMTP_USERNAME=infrait@frlp.utn.edu.ar
SMTP_PASSWORD=__SMTP_PASSWORD__
SMTP_FROM=infrait@frlp.utn.edu.ar
SMTP_FROM_NAME="Vaultwarden GIDAS"
